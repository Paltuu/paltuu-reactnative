{
  "cli": {
    "version": ">= 16.26.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_ENV": "development"
      }
    },
    "ios-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      },
      "channel": "ios-simulator",
      "env": {
        "APP_ENV": "development"
      }
    },
    "preview": {
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_API_URL": "https://www.paltuu.pk/api"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://www.paltuu.pk/api"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "[YOUR_APPLE_ID_HERE]",
        "companyName": "[YOUR_COMPANY_NAME_HERE]",
        "ascAppId": "[YOUR_APP_STORE_CONNECT_APP_ID_HERE]",
        "bundleIdentifier": "com.paltuu.app"
      }
    }
  }
}
